<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
        http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">

    <error-handler name="apikit-error">
        <on-error-propagate type="APP:VALIDATION_ERROR">
            <set-variable variableName="httpStatus" value="400"/>
            <set-variable variableName="errorCategory" value="validation"/>
            <flow-ref name="build-canonical-error-sf"/>
        </on-error-propagate>
        <on-error-propagate type="APP:IDEMPOTENCY_CONFLICT">
            <set-variable variableName="httpStatus" value="409"/>
            <set-variable variableName="errorCategory" value="validation"/>
            <flow-ref name="build-canonical-error-sf"/>
        </on-error-propagate>
        <on-error-propagate type="APP:DEPENDENCY_ERROR, HTTP:CONNECTIVITY, HTTP:TIMEOUT">
            <set-variable variableName="httpStatus" value="503"/>
            <set-variable variableName="errorCategory" value="dependency"/>
            <flow-ref name="build-canonical-error-sf"/>
        </on-error-propagate>
        <on-error-propagate type="APIKIT:BAD_REQUEST, APIKIT:NOT_FOUND, APIKIT:METHOD_NOT_ALLOWED, APIKIT:NOT_ACCEPTABLE, APIKIT:UNSUPPORTED_MEDIA_TYPE">
            <set-variable variableName="httpStatus" value="#[attributes.statusCode default 400]"/>
            <set-variable variableName="errorCategory" value="validation"/>
            <flow-ref name="build-canonical-error-sf"/>
        </on-error-propagate>
        <on-error-propagate type="ANY">
            <set-variable variableName="httpStatus" value="500"/>
            <set-variable variableName="errorCategory" value="internal"/>
            <flow-ref name="build-canonical-error-sf"/>
        </on-error-propagate>
    </error-handler>

    <sub-flow name="build-canonical-error-sf">
        <ee:transform>
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  error_code: (error.errorType.identifier default "INTERNAL_ERROR") as String,
  error_message: (error.description default "Unexpected runtime failure") as String,
  error_category: (vars.errorCategory default "internal") as String,
  correlation_id: correlationId default null,
  timestamp: now() as String,
  retryable: ((vars.errorCategory default "internal") == "dependency")
}]]></ee:set-payload>
            </ee:message>
            <ee:variables>
                <ee:set-variable variableName="outboundHeaders"><![CDATA[%dw 2.0
output application/java
---
{
  "content-type": "application/json",
  "x-correlation-id": correlationId default ""
}]]></ee:set-variable>
            </ee:variables>
        </ee:transform>
        <logger level="ERROR" category="error.canonical"
                message="#['correlationId=' ++ (correlationId as String) ++ ' httpStatus=' ++ ((vars.httpStatus default 500) as String) ++ ' error_code=' ++ ((error.errorType.identifier default 'INTERNAL_ERROR') as String) ++ ' error_category=' ++ ((vars.errorCategory default 'internal') as String) ++ ' retryable=' ++ (((vars.errorCategory default 'internal') as String) == 'dependency')]"/>
    </sub-flow>
</mule>
