  "item": [
    {
      "name": "Create Analysis Job",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "X-Correlation-Id",
            "value": "{{correlationId}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "client_id",
            "value": "{{clientId}}"
          },
          {
            "key": "client_secret",
            "value": "{{clientSecret}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/analysis-jobs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "analysis-jobs"
          ]
        },
        "description": "Auto-generated request for Create Analysis Job.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idempotencyKey\": \"idem-001\",\n  \"sourceSystems\": [\n    \"anypoint\"\n  ],\n  \"filter\": {\n    \"startTime\": \"{{startTime}}\",\n    \"endTime\": \"{{endTime}}\",\n    \"environment\": \"dev\",\n    \"severity\": [\n      \"ERROR\"\n    ]\n  },\n  \"requestedBy\": \"postman-user\",\n  \"priority\": \"normal\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is expected', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([202]);",
              "});",
              "pm.test('Response contains jobId', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(data.jobId).to.be.a('string').and.not.empty;",
              "  pm.environment.set('jobId', data.jobId);",
              "});",
              "pm.test('Response time is under 5s', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ]
          }
        }
      ]
    },
